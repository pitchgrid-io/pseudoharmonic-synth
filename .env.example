APP_NAME='PseudoHarmonic'
APP_VERSION='0.2.1'
BUNDLE_ID='io.pitchgrid.pseudoharmonic'

# macOS code signing
CODESIGN_IDENTITY='Developer ID Application: Your Name (TEAM_ID)'
APPLE_ID='your-apple-id@email.com'
